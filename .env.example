# -----------------------------
# Core app environment
# -----------------------------
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://s3gator:s3gator@localhost:5432/s3gator

# 32+ char symmetric key used for encrypting DB-stored secrets.
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=replace-with-64-hex-chars

# Session/cookie settings
SESSION_COOKIE_NAME=s3gator_sid
SESSION_TTL_HOURS=24
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=300

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true
REDIS_PREFIX=s3gator

# Worker / Jobs
JOB_WORKER_INLINE=false
JOB_WORKER_POLL_MS=2000
JOB_LOCK_TTL_SECONDS=60
JOB_RETRY_MAX_ATTEMPTS_BUCKET_SYNC=5
JOB_RETRY_MAX_ATTEMPTS_UPLOAD_CLEANUP=3
JOB_RETRY_MAX_ATTEMPTS_RETENTION_CLEANUP=3
JOB_RETRY_BACKOFF_SECONDS_BUCKET_SYNC=15
JOB_RETRY_BACKOFF_SECONDS_UPLOAD_CLEANUP=30
JOB_RETRY_BACKOFF_SECONDS_RETENTION_CLEANUP=60
JOB_RETRY_MAX_BACKOFF_SECONDS=900

# Operational retention windows (days)
RETENTION_JOB_EVENTS_DAYS=30
RETENTION_FAILED_JOB_DAYS=90
RETENTION_TERMINAL_JOB_DAYS=30
RETENTION_AUDIT_LOG_DAYS=180
RETENTION_SECURITY_AUDIT_DAYS=365
RETENTION_UPLOAD_SESSION_DAYS=30
RETENTION_ARCHIVE_ENABLED=false
RETENTION_ARCHIVE_BATCH_SIZE=500

# Scheduled maintenance (single-leader via Redis lock)
MAINTENANCE_SCHEDULER_ENABLED=false
MAINTENANCE_SCHEDULER_TICK_SECONDS=30
MAINTENANCE_SCHEDULER_LOCK_TTL_SECONDS=60
MAINTENANCE_RETENTION_INTERVAL_MINUTES=360
MAINTENANCE_UPLOAD_CLEANUP_INTERVAL_MINUTES=30
MAINTENANCE_BUCKET_SYNC_INTERVAL_MINUTES=0

# Multipart durability
UPLOAD_SESSION_TTL_HOURS=24
UPLOAD_PART_SIZE_BYTES=10485760
UPLOAD_CLEANUP_BATCH_SIZE=50

# Bootstrap admin account (used by seed script)
DEFAULT_SUPER_ADMIN_USERNAME=admin
DEFAULT_SUPER_ADMIN_PASSWORD=change-me-now-please
DEFAULT_SUPER_ADMIN_EMAIL=admin@example.local

# Default Garage connection seeded into DB
GARAGE_ENDPOINT=http://127.0.0.1:3900
GARAGE_REGION=garage
GARAGE_FORCE_PATH_STYLE=true
GARAGE_ACCESS_KEY_ID=replace-me
GARAGE_SECRET_ACCESS_KEY=replace-me
GARAGE_ADMIN_API_URL=http://127.0.0.1:3903
GARAGE_ADMIN_TOKEN=replace-me

# Correlation / telemetry
CORRELATION_HEADER_NAME=x-request-id
OTEL_ENABLED=false
OTEL_SERVICE_NAME=s3gator-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=

# Web app -> API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---------------------------------------------------
# Optional integration lane overrides (docker compose)
# ---------------------------------------------------
INTEGRATION_GARAGE_ADMIN_TOKEN=stage4-dev-admin-token-change-me
INTEGRATION_GARAGE_ACCESS_KEY_ID=GK111111111111111111111111
INTEGRATION_GARAGE_SECRET_ACCESS_KEY=1111111111111111111111111111111111111111111111111111111111111111
INTEGRATION_GARAGE_BUCKET_NAME=s3gator-integration
INTEGRATION_BUCKET_NAME=integration-bucket
INTEGRATION_ADMIN_USERNAME=admin
INTEGRATION_ADMIN_PASSWORD=change-me-now-please
INTEGRATION_API_BASE_URL=http://127.0.0.1:4000
INTEGRATION_COMPOSE_FILE=./docker-compose.integration.yml
INTEGRATION_GARAGE_ENDPOINT=http://127.0.0.1:3900
INTEGRATION_GARAGE_REGION=garage
INTEGRATION_GARAGE_FORCE_PATH_STYLE=true
INTEGRATION_WORKER_CONTAINER=s3gator-int-worker
INTEGRATION_SECONDARY_WORKER_CONTAINER=s3gator-int-worker-2
INTEGRATION_JOB_WORKER_POLL_MS=1500
INTEGRATION_JOB_LOCK_TTL_SECONDS=20
INTEGRATION_RETENTION_ARCHIVE_ENABLED=false
INTEGRATION_RETENTION_ARCHIVE_BATCH_SIZE=500
INTEGRATION_MAINTENANCE_SCHEDULER_ENABLED_API=false
INTEGRATION_MAINTENANCE_SCHEDULER_ENABLED_WORKER=true
INTEGRATION_MAINTENANCE_SCHEDULER_TICK_SECONDS=30
INTEGRATION_MAINTENANCE_SCHEDULER_LOCK_TTL_SECONDS=60
INTEGRATION_MAINTENANCE_RETENTION_INTERVAL_MINUTES=360
INTEGRATION_MAINTENANCE_UPLOAD_CLEANUP_INTERVAL_MINUTES=30
INTEGRATION_MAINTENANCE_BUCKET_SYNC_INTERVAL_MINUTES=0
INTEGRATION_RELIABILITY_FILE_COUNT=300
INTEGRATION_RELIABILITY_WAIT_FOR_RUNNING_MS=30000
INTEGRATION_RELIABILITY_WAIT_FOR_TERMINAL_MS=240000
INTEGRATION_RELIABILITY_V2_WAIT_FOR_RETRY_MS=180000
INTEGRATION_RELIABILITY_V2_WAIT_FOR_COMPLETION_MS=300000
