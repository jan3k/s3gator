# -----------------------------
# Core app environment
# -----------------------------
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
DATABASE_URL=postgresql://s3gator:s3gator@localhost:5432/s3gator

# 32+ char symmetric key used for encrypting DB-stored secrets.
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=replace-with-64-hex-chars

# Session/cookie settings
SESSION_COOKIE_NAME=s3gator_sid
SESSION_TTL_HOURS=24
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=300
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true
REDIS_PREFIX=s3gator

# Worker / Jobs
JOB_WORKER_INLINE=false
JOB_WORKER_POLL_MS=2000
JOB_LOCK_TTL_SECONDS=60

# Multipart durability
UPLOAD_SESSION_TTL_HOURS=24
UPLOAD_PART_SIZE_BYTES=10485760
UPLOAD_CLEANUP_BATCH_SIZE=50

# Bootstrap admin account (used by seed script)
DEFAULT_SUPER_ADMIN_USERNAME=admin
DEFAULT_SUPER_ADMIN_PASSWORD=change-me-now-please
DEFAULT_SUPER_ADMIN_EMAIL=admin@example.local

# Optional default Garage connection seeded into DB
GARAGE_ENDPOINT=http://127.0.0.1:3900
GARAGE_REGION=garage
GARAGE_FORCE_PATH_STYLE=true
GARAGE_ACCESS_KEY_ID=replace-me
GARAGE_SECRET_ACCESS_KEY=replace-me
GARAGE_ADMIN_API_URL=http://127.0.0.1:3903
GARAGE_ADMIN_TOKEN=replace-me

# Web app -> API base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
